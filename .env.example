# ─────────────────────────────────────────────────────────────
# A A Tech WMS — environment variables
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env.local` for development, fill in real
# values, NEVER commit `.env.local`. For production, set these
# in the Vercel project's Environment Variables UI.
#
# Variables prefixed with `NEXT_PUBLIC_` are inlined into the
# client bundle and are visible to anyone who loads the app —
# only put values there that you're OK exposing publicly.
# Everything else is server-only.
# ─────────────────────────────────────────────────────────────


# ── DATABASE (required) ──────────────────────────────────────
# Supabase Postgres connection string. Use the POOLER url, not
# the direct one.
#
# Port 5432  = session-mode pooler (use for one-off tsx scripts
#               that may use prepared statements or session
#               state — e.g. drizzle-kit, scripts/import-*.ts).
# Port 6543  = transaction-mode pooler (use for the deployed
#               Next app — handles far more concurrent
#               serverless function invocations). The app code
#               already runs with `prepare: false` to be
#               compatible (see lib/db/index.ts).
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# Optional: separate URL for `pnpm test:integration` against a
# scratch DB. If unset, integration tests are skipped.
DATABASE_URL_TEST=""

# ── SUPABASE (required) ──────────────────────────────────────
# Project URL + anon key. Find at:
#   Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Service-role key — used by lib/supabase/admin.ts for Storage
# operations (document uploads, signed download URLs) and any
# server-only writes that bypass RLS. **Treat as a root password.**
# Never expose in the client bundle (no NEXT_PUBLIC_ prefix).
SUPABASE_SERVICE_ROLE_KEY=""

# ── FIREBASE AUTH (required) ─────────────────────────────────
# Client config — these end up in the browser bundle (safe).
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="<project-ref>.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# Admin SDK service-account credentials — server-only.
# Download a JSON service-account key from:
#   Firebase Console → Project Settings → Service Accounts
# `FIREBASE_PRIVATE_KEY` keeps its literal `\n` newlines in env;
# the code calls `.replace(/\\n/g, "\n")` when it loads.
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# Two rotating secrets used to sign the `__session` cookie. To
# rotate: move CURRENT → PREVIOUS, generate a fresh CURRENT.
# Anything random + long works (`openssl rand -base64 48`).
COOKIE_SECRET_CURRENT=""
COOKIE_SECRET_PREVIOUS=""

# ── APP (required) ───────────────────────────────────────────
# The canonical public URL of this deployment. Used in email
# links, invite redirects, Slack/WhatsApp callbacks, etc.
NEXT_PUBLIC_SITE_URL="https://wms.mananvasa.com"

# ── EMAIL (optional — notifications degrade if unset) ────────
# Resend transactional-email account.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="A A Tech Dashboard <onboarding@resend.dev>"

# ── SLACK (optional) ─────────────────────────────────────────
# Bot token from the A A Tech Slack app. Required for
# Slack-channel notifications + the integration health check.
SLACK_BOT_TOKEN=""

# ── WHATSAPP (optional) ──────────────────────────────────────
# Meta Cloud API credentials. See docs/runbooks/whatsapp-setup.md.
META_WHATSAPP_VERIFY_TOKEN=""
META_WHATSAPP_ACCESS_TOKEN=""
META_WHATSAPP_PHONE_NUMBER_ID=""
# Legacy aliases (some helpers read these names too).
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# ── WEB PUSH (optional) ──────────────────────────────────────
# VAPID keys for browser push subscriptions. Generate with:
#   pnpm web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@aatech.in"

# ── NPD ⇄ GOOGLE SHEET MIRROR (optional) ─────────────────────
# Postgres is the system of record for NPD; the Google Sheet is
# a live two-way mirror of it. Leave these blank and the app
# works exactly as before, minus the sheet (the NPD page shows
# "Sheet not linked" and no sync is attempted).
#
# Full setup: apps-script/README.md (5 minutes, no Google Cloud
# project and no service-account key required).
#
# The /exec URL of the Apps Script Web App bound to the sheet.
# Get it from: Apps Script editor → Deploy → New deployment →
# type "Web app" → Execute as: Me, Who has access: Anyone.
NPD_SHEET_WEBAPP_URL=""

# Shared secret authenticating BOTH directions (app → script and
# script → app). An Apps Script web app must be deployed as
# "Anyone" to be callable at all, so there is no Google identity
# to check — this secret IS the entire security boundary. Make it
# long and random (`openssl rand -base64 48`) and set the SAME
# value in the Apps Script editor under
#   Project Settings → Script Properties → SHEET_SECRET
# If it's unset here, the webhook fails CLOSED and rejects
# everything, rather than accepting everything.
NPD_SHEET_SECRET=""

# Human-facing URL of the sheet — only used to render the "open
# the sheet ↗" link on the NPD page. Cosmetic.
NPD_SHEET_URL="https://docs.google.com/spreadsheets/d/1Q293m1HEKtFMVAOURJ0jVNDmiSDlElueOw--5Nq2fc0/edit"

# ── CRON (required for /api/cron/* routes) ───────────────────
# Shared secret the Vercel cron scheduler sends in
# `Authorization: Bearer ...`. Vercel auto-sets this for cron
# invocations; set the same value locally if running crons
# manually.
CRON_SECRET=""

# ── OBSERVABILITY (optional) ─────────────────────────────────
# Phase 0.1 — slow-query threshold in milliseconds. Anything
# >= this duration gets logged as `[slow-query] <ms>ms — <sql>`
# from the postgres-js client wrapper. Auto-on at 300ms in
# `development`; off by default elsewhere unless set.
SLOW_QUERY_MS="300"

# Phase 0.2 — Sentry. The SDK is wired (sentry.{server,edge,client}.config.ts
# + instrumentation.ts + instrumentation-client.ts) but **dormant until
# DSN is set**. Create the Sentry project, paste the DSN below, and the
# next deploy ships errors + 20% perf traces.
NEXT_PUBLIC_SENTRY_DSN=""
# Optional overrides (sensible defaults baked in if unset):
#   SENTRY_TRACES_SAMPLE_RATE              — server perf sampling (0.2)
#   NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE  — client perf sampling (0.2)
#   SENTRY_ENABLE_DEV                      — forward NODE_ENV=development errors
#   NEXT_PUBLIC_SENTRY_ENABLE_DEV          — same, client-side
#   NEXT_PUBLIC_SENTRY_ENABLE_REPLAY       — turn on session replay (privacy
#                                            trade-off; masks text + media)

# ── DEV-ONLY TOGGLES ─────────────────────────────────────────
# Set to "true" for HTTP local-server deploys (no TLS) so the
# session cookie isn't dropped. **Never set in production.**
ALLOW_INSECURE_COOKIES=""

# Point at a local Firebase Auth emulator instead of the live
# project. Used by the offline-emulator dev flow + the visual
# e2e tests under `tests/visual/*`.
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=""
FIREBASE_AUTH_EMULATOR_HOST=""

# Set to "true" to silence the realtime "live indicator" in the
# header during dev sessions where the realtime channel is noisy.
NEXT_PUBLIC_DISABLE_REALTIME=""
