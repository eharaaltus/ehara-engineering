# Carbide India Dashboard — local Windows server .env.local template
#
# Copy this file to `.env.local` at the repo root and replace the
# placeholders. Do NOT commit `.env.local` — it is gitignored.
#
# Values marked [GENERATE] should be filled with a long random string,
# e.g. with PowerShell:
#   -join ((48..57 + 97..122) | Get-Random -Count 48 | % {[char]$_})

# ─── Local Postgres on this Windows server ────────────────────────
# REPLACE <PASSWORD> with the password you set for the `postgres` user
# during PostgreSQL installation. The database `carbide_india` will be
# created automatically by `pnpm setup:local-postgres`.
DATABASE_URL="postgresql://postgres:<PASSWORD>@localhost:5432/carbide_india"

# ─── Firebase Auth (cloud) — same project as Vercel deployment ────
# These values come from Firebase Console → Project Settings → General →
# Your apps → Web app config.
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSyATjrr2gfQ3BQmGpeNM1FCEUEmE-uZ1HTA"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="carbide-india-7975c.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="carbide-india-7975c"
NEXT_PUBLIC_FIREBASE_APP_ID="1:232857955013:web:1f5c823583fe8e454f1eac"

# Firebase Admin SDK — from the service account JSON.
FIREBASE_PROJECT_ID="carbide-india-7975c"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-fbsvc@carbide-india-7975c.iam.gserviceaccount.com"
# IMPORTANT: keep the \n sequences as LITERAL backslash-n in the value;
# the runtime decodes them. Wrap the entire value in double quotes.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<paste-private-key-here>\n-----END PRIVATE KEY-----\n"

# ─── Cookie signing — generate fresh random values for this server ─
COOKIE_SECRET_CURRENT="[GENERATE-48-CHAR-RANDOM]"
COOKIE_SECRET_PREVIOUS="[GENERATE-48-CHAR-RANDOM]"

# Allow HTTP cookies (no TLS on LAN). Without this, sessions break.
ALLOW_INSECURE_COOKIES="true"

# ─── Cron secret — anyone calling /api/cron must send this ────────
CRON_SECRET="[GENERATE-32-CHAR-RANDOM]"

# ─── Site URL — REPLACE <LAN-IP> with this server's static LAN IP ─
# Example: http://192.168.1.100:3000
# Find it with `ipconfig` on the server. This URL is used in invite
# emails and password-reset redirects.
NEXT_PUBLIC_SITE_URL="http://<LAN-IP>:3000"

# ─── Supabase placeholders ────────────────────────────────────────
# Realtime is disabled in local mode (set below). These values just need
# to pass URL-format validation; they are never actually contacted.
NEXT_PUBLIC_SUPABASE_URL="http://localhost:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="local_unused_realtime_disabled_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Hide the "Live" badge in the header — there is no realtime server on LAN.
NEXT_PUBLIC_DISABLE_REALTIME="true"

# ─── Resend (email) ────────────────────────────────────────────────
# Not configured. Bootstrap-admin will print password-reset links to the
# console instead of emailing them. When you invite employees, you will
# need to share the reset link manually until Resend is set up.
# RESEND_API_KEY=""
# RESEND_FROM_EMAIL=""
