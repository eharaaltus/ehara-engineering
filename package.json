{
  "name": "ehara-engineering-wms",
  "version": "0.1.0",
  "private": true,
  "description": "Ehara Engineering Work Management System — WMS, NPD tracker & operations dashboard",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "rm -rf .next && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=.env.local scripts/apply-all-migrations.ts --apply",
    "db:migrate:dry": "tsx --env-file=.env.local scripts/apply-all-migrations.ts",
    "db:studio": "node --env-file=.env.local node_modules/drizzle-kit/bin.cjs studio",
    "seed": "tsx --env-file=.env.local scripts/seed.ts",
    "seed:reset": "tsx --env-file=.env.local scripts/seed-reset.ts",
    "seed:firebase": "tsx --env-file=.env.local scripts/seed-firebase.ts",
    "sync:departments": "tsx --env-file=.env.local scripts/sync-departments.ts",
    "verify:env": "tsx --env-file=.env.local scripts/verify-env.ts",
    "emul": "firebase emulators:start --only auth",
    "dev:full": "concurrently -k -n web,emul \"pnpm dev\" \"pnpm emul\"",
    "bootstrap-admin": "tsx --env-file=.env.bootstrap scripts/bootstrap-admin.ts",
    "import:legacy": "tsx --env-file=.env.local scripts/import-legacy.ts",
    "gen:icons": "python scripts/gen-pwa-icons.py",
    "setup:local-postgres": "tsx --env-file=.env.local scripts/setup-local-postgres.ts",
    "setup:local": "pnpm setup:local-postgres && pnpm db:migrate",
    "db:migrate:legacy-drizzle-kit": "node --env-file=.env.local node_modules/drizzle-kit/bin.cjs migrate",
    "start:lan": "next start -H 0.0.0.0 -p 3000"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroui/framer-utils": "^2.1.28",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@sentry/nextjs": "^10.53.1",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.1",
    "@slack/web-api": "^7.15.2",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "csv-parse": "^6.2.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.9.0",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "next": "^16.2.6",
    "next-firebase-auth-edge": "^1.12.0",
    "nuqs": "^2.8.9",
    "ogl": "^1.0.11",
    "pdfkit": "^0.18.0",
    "postgres": "^3.4.9",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.0",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.78.0",
    "react-window": "^2.2.7",
    "recharts": "^3.8.1",
    "resend": "^6.12.3",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.2",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^2.0.0",
    "@types/web-push": "^3.6.4",
    "@vitest/ui": "^4.1.5",
    "concurrently": "^9.2.1",
    "csv-stringify": "^6.7.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.6",
    "firebase-tools": "^15.17.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
